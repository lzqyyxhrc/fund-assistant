# ==================================================================
# 基金智能定投助手 - 环境变量模板
#
# 使用步骤：
#   1. 把本文件复制一份改名为 .env（.env 已在 .gitignore 中，不会上传 Git）
#   2. 把下面的占位符换成你自己的真实 key
#   3. 重新启动应用即可自动加载
#
# 说明：
#   - 所有字段都是可选的，缺失时对应功能会自动降级或跳过
#   - 名称必须完全一致（大小写敏感）
# ==================================================================

# ---- FRED（美国宏观数据，用于纳指/黄金估值）----
# 免费申请：https://fred.stlouisfed.org/docs/api/api_key.html
FRED=your_fred_api_key_here

# ---- FMP（黄金/白银现货价，用于金银比 & Gold/PPI）----
# 免费申请：https://site.financialmodelingprep.com/developer/docs
FMP=your_fmp_api_key_here

# ---- 蛋卷基金 Cookie（用于纳指PE/红利PE等蛋卷官方估值）----
# 获取方式：登录 https://danjuanfunds.com 后在 DevTools 网络面板复制 Cookie 请求头整行
DANJUAN_COOKIE=device_id=...; xq_a_token=...; u=...

# ---- DeepSeek（可选，用于 AI 生成投资日报）----
# 申请：https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here

# ---- 飞书 Webhook（可选，用于把日报推送到群）----
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# ---- Docker 环境变量（可选）----
# 以下变量用于 Docker 部署时的容器配置
# STREAMLIT_PORT=8501
